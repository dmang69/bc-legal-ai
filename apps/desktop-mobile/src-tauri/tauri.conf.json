{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BC Legal AI Associate",
  "version": "0.1.0",
  "identifier": "ca.bclegalai.associate",
  "build": {
    "frontendDist": "../../platform-ui/dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "npm run dev --prefix ../platform-ui",
    "beforeBuildCommand": "npm run build --prefix ../platform-ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "BC Legal AI Workbench",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:* https:; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "BC Legal AI Associate — supervised legal support",
    "longDescription": "BC Legal AI Associate (Workbench / Client). Human-supervised legal research, evidence, and drafting support. Not a lawyer. Not legal advice. Private backend only.",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": null,
      "entitlements": null
    }
  },
  "plugins": {}
}
