{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BC Legal AI Associate",
  "version": "0.1.0",
  "identifier": "ca.bclegalai.associate",
  "build": {
    "frontendDist": "../../../frontend/client",
    "devUrl": "http://127.0.0.1:8000",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "BC Legal AI Associate",
        "width": 1100,
        "height": 780,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:* https:; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "category": "Productivity",
    "shortDescription": "BC legal research and drafting support (supervised)",
    "longDescription": "BC Legal AI Associate is a human-supervised legal research, evidence, and drafting support workbench. Not a lawyer. Not legal advice.",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": null,
      "entitlements": null
    }
  },
  "plugins": {}
}
