# Example Vault Agent config — not active until Vault is provisioned.
pid_file = "./pidfile"

auto_auth {
  method "kubernetes" {
    mount_path = "auth/kubernetes"
    config = {
      role = "ala-app"
    }
  }
}

template {
  destination = "/secrets/ala.env"
  contents    = <<EOT
{{ with secret "secret/data/ala/postgres" }}
ALA_POSTGRES_URL={{ .Data.data.url }}
{{ end }}
EOT
}
